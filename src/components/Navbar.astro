---
const links = [
    { label: "Sobre mí", href: "#sobre-mi" },
    { label: "Proyectos", href: "#proyectos" },
    { label: "Habilidades", href: "#habilidades" },
    { label: "Contacto", href: "#contacto" },
];
---

<nav
    class="fixed top-0 left-0 right-0 z-50 border-b backdrop-blur-md"
    style={`background-color: rgba(10,10,10,0.8); border-color: var(--color-border);`}
>
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a
            href="/"
            class="text-lg font-bold"
            style={`color: var(--color-text);`}
        >
            AF<span style={`color: var(--color-accent);`}>.</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class="text-sm transition-colors hover:text-white"
                        style={`color: var(--color-text-secondary);`}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>
        <button
            id="mobile-menu-btn"
            class="md:hidden"
            style={`color: var(--color-text-secondary);`}
            aria-label="Abrir menú"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden px-6 pb-4 flex-col gap-4">
        {
            links.map((link) => (
                <a
                    href={link.href}
                    class="text-sm py-2 transition-colors hover:text-white"
                    style={`color: var(--color-text-secondary);`}
                >
                    {link.label}
                </a>
            ))
        }
    </div>
</nav>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        menu?.classList.toggle("flex");
    });
</script>
