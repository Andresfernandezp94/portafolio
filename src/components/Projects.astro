---
import ProjectCard from "./ProjectCard.astro";
import { getReposWithLanguages } from "../lib/github";

const projects = [
    {
        name: "Motor de Facturación de Billetera",
        description:
            "Sistema de débito de billetera de alta concurrencia construido en AWS.",
        stack: ["AWS", "DynamoDB", "Lambda"],
        highlights: [
            "Maneja 1200+ workers concurrentes",
            "Arquitectura de débito atómico",
            "Consistencia basada en ledger",
        ],
        slug: "wallet",
    },
];

const repos = await getReposWithLanguages("Andresfernandezp94");
---

<section id="proyectos" class="py-20 px-6 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold mb-2">Proyectos</h2>
    <div
        class="w-12 h-1 rounded mb-8"
        style={`background-color: var(--color-accent);`}
    >
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => <ProjectCard {...project} />)}
    </div>

    <h3 class="text-2xl font-bold mt-16 mb-2">Repositorios en GitHub</h3>
    <div
        class="w-12 h-1 rounded mb-8"
        style={`background-color: var(--color-accent);`}
    >
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
            repos.map((repo) => (
                <div
                    class="rounded-xl p-6 transition-all duration-300 hover:-translate-y-1"
                    style={`background-color: var(--color-bg-card); border: 1px solid var(--color-border);`}
                >
                    <h3 class="text-xl font-bold mb-2">{repo.name}</h3>
                    <p
                        class="text-sm mb-4"
                        style={`color: var(--color-text-secondary);`}
                    >
                        {repo.description || "Sin descripción"}
                    </p>

                    <div class="flex flex-wrap gap-2 mb-4">
                        {repo.languages.map((lang) => (
                            <span
                                class="text-xs px-2 py-1 rounded-md font-medium"
                                style={`background-color: var(--color-accent-light); color: var(--color-accent);`}
                            >
                                {lang.language}
                            </span>
                        ))}
                    </div>

                    <a
                        href={repo.html_url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-medium transition-colors"
                        style={`color: var(--color-accent);`}
                    >
                        Ver Repositorio →
                    </a>
                </div>
            ))
        }
    </div>
</section>
